{
  "manifest_version": 3,
  "name": "Friction",
  "version": "1.0",
  "permissions": ["storage"],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Friction Settings"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "friction-extension@yourdomain.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
         "required": ["none"]
      }
    }
  }
}
